# ============================================
# CALENDARLY — Environmental Configuration Template
# ============================================

# --- Server Configurations ---
PORT=3000
NODE_ENV=development

# Shared API token — REQUIRED. Every /api request must send it as
#   Authorization: Bearer <token>   (or)   x-api-key: <token>
# The server fails closed (refuses all requests) if this is unset.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_AUTH_TOKEN=

# Transparent Database Encryption Key (sqlcipher requirement)
# Change this to a secure, long passphrase for your production instance!
DB_ENCRYPTION_KEY="your-super-secure-high-entropy-passphrase"

# Custom SQLite database location path.
# Docker: /data/calendarly.db | Local: leave empty (defaults to server/calendarly.db)
DATABASE_PATH=

# --- Secret Upload ---
# Password for the hidden /secret-upload page (graphify archive upload)
SECRET_UPLOAD_PASSWORD=change-me-in-production

# --- Client Configurations ---
# Target URL for the Vite development proxy
VITE_BACKEND_URL=http://localhost:3000

# --- Gemini CLI / External Stats ---
# Endpoint for session telemetry and statistics (your private server URL)
AGENTS_API_URL=
GEMINI_EXTERNAL_STATS_API=
GEMINI_AGENT_NAME=Gemini
GEMINI_TELEMETRY_ENABLED=true
GEMINI_TELEMETRY_OTLP_ENDPOINT=
