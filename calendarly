#!/bin/bash

# Calendarly CLI Tool
# Usage: ./calendarly [command]

COMMAND=$1

case $COMMAND in
  backup)
    echo "Creating database backup..."
    docker exec calendarly-backend node backup-db.js
    ;;
  restart)
    echo "Backing up before restart..."
    docker exec calendarly-backend node backup-db.js
    echo "Restarting server..."
    docker-compose down && docker-compose up --build -d
    ;;
  status)
    docker-compose ps
    ;;
  logs)
    docker-compose logs -f
    ;;
  *)
    echo "Usage: ./calendarly {backup|restart|status|logs}"
    exit 1
    ;;
esac
